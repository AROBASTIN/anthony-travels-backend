# ============================================================
# Example environment template — safe to commit
# Copy this to .env and fill in real values
# ============================================================

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/anthony_travels?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB_NAME=anthony_travels

DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

JWT_SECRET_KEY=your-jwt-secret-key-here
